{
  "name": "wcag-checker",
  "version": "0.1.0",
  "description": "Local WCAG 2.2 AA accessibility checker for URLs, HTML, and PDFs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "smoke": "node test/smoke.js",
    "test": "node test/smoke.js",
    "install:verapdf": "node scripts/install-verapdf.js",
    "postinstall": "playwright install chromium && node scripts/install-verapdf.js"
  },
  "keywords": [
    "wcag",
    "wcag22",
    "accessibility",
    "a11y",
    "axe-core",
    "verapdf",
    "pdf-ua",
    "audit"
  ],
  "license": "MIT",
  "author": "Sammie Rosado",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sammierosado/wcag-checker.git"
  },
  "bugs": {
    "url": "https://github.com/sammierosado/wcag-checker/issues"
  },
  "homepage": "https://github.com/sammierosado/wcag-checker#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.10.0",
    "axe-core": "^4.10.0",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "playwright": "^1.47.0"
  }
}
